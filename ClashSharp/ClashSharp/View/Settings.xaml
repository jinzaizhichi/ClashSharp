<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashSharp.View.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:ClashSharp.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        Padding="32,32,20,32"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18" MaxWidth="920" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitleText" Text="{Binding PageTitleText}" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock x:Name="DescriptionText" Text="{Binding DescriptionText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock x:Name="LanguageSectionTitleText" Text="{Binding LanguageSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <components:SettingRow x:Name="LanguageRow" Title="{Binding LanguageTitleText}" Description="{Binding LanguageDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="LanguageBox" MinWidth="180" SelectedIndex="{Binding DisplayLanguageIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="简体中文" />
                        <ComboBoxItem Content="繁體中文" />
                        <ComboBoxItem Content="English" />
                        <ComboBoxItem Content="Русский" />
                        <ComboBoxItem Content="Français" />
                        <ComboBoxItem Content="Deutsch" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="ProxySectionTitleText" Text="{Binding ProxySectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="TransparentProxyRow" Title="{Binding TransparentProxyTitleText}" Description="{Binding TransparentProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TransparentProxyToggle" IsOn="{Binding TransparentProxyEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="TunFallbackRow" Title="{Binding TunFallbackTitleText}" Description="{Binding TunFallbackDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="TunFallbackToggle" IsOn="{Binding FallbackToSystemProxyWhenTunFails, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MixedPortRow" Title="{Binding MixedPortTitleText}" Description="{Binding MixedPortDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="MixedPortBox" Width="140" Minimum="1" Maximum="65535" Value="{Binding MixedPortValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ConnectionTestUrlRow" Title="{Binding ConnectionTestUrlTitleText}" Description="{Binding ConnectionTestUrlDescriptionText}">
                <components:SettingRow.ActionContent>
                    <TextBox x:Name="ConnectionTestUrlBox" MinWidth="260" Text="{Binding ConnectionTestUrl, Mode=OneWay}" LostFocus="ConnectionTestUrlBox_LostFocus" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="96">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="ProxyInformationTitleText" Text="{Binding ProxyInformationTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="ProxyInformationDescriptionText" Text="{Binding ProxyInformationDescriptionText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ProxyLocalEntryText" Text="{Binding ProxyLocalEntryText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="ProxyCoreConfigurationText" Text="{Binding ProxyCoreConfigurationText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="ProxyCoreBinaryText" Text="{Binding ProxyCoreBinaryText}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>

            <components:SettingRow x:Name="ConnectionSamplingRow" Title="{Binding ConnectionSamplingTitleText}" Description="{Binding ConnectionSamplingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="ConnectionSamplingToggle" IsOn="{Binding ConnectionSamplingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="SamplingIntervalRow" Title="{Binding SamplingIntervalTitleText}" Description="{Binding SamplingIntervalDescriptionText}">
                <components:SettingRow.ActionContent>
                    <NumberBox x:Name="ConnectionSamplingIntervalBox" Width="140" Minimum="5" Maximum="3600" Value="{Binding ConnectionSamplingIntervalSecondsValue, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="WindowsNativeSectionTitleText" Text="{Binding WindowsNativeSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <Grid Style="{StaticResource ClashCardGridStyle}" MinHeight="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock x:Name="WindowsNativeTitleText" Text="{Binding WindowsNativeTitleText}" Style="{ThemeResource BodyTextBlockStyle}" />
                    <TextBlock x:Name="WindowsNativeDescriptionText" Text="{Binding WindowsNativeDescriptionText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Margin="12,0,0,0" Click="OpenNetworkRepairButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                        <TextBlock x:Name="OpenNetworkRepairText" Text="{Binding OpenText}" />
                    </StackPanel>
                </Button>
            </Grid>

            <components:SettingRow x:Name="CheckStaleProxyRow" Title="{Binding CheckStaleProxyTitleText}" Description="{Binding CheckStaleProxyDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="CheckStaleProxyToggle" IsOn="{Binding CheckStaleProxyOnStartup, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="RestoreProxyOnExitRow" Title="{Binding RestoreProxyOnExitTitleText}" Description="{Binding RestoreProxyOnExitDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="RestoreProxyOnExitToggle" IsOn="{Binding RestoreProxyOnExit, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ProxyRecoveryModeRow" Title="{Binding ProxyRecoveryModeTitleText}" Description="{Binding ProxyRecoveryModeDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="ProxyRecoveryModeBox" MinWidth="180" SelectedIndex="{Binding ProxyRecoveryModeIndex, Mode=TwoWay}">
                        <ComboBoxItem x:Name="ProxyRecoveryIgnoreItem" Content="{Binding ProxyRecoveryIgnoreText}" />
                        <ComboBoxItem x:Name="ProxyRecoveryEnableItem" Content="{Binding ProxyRecoveryEnableText}" />
                        <ComboBoxItem x:Name="ProxyRecoveryDisableItem" Content="{Binding ProxyRecoveryDisableText}" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="MainlandChinaSectionTitleText" Text="{Binding MainlandChinaSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="MainlandChinaDisplayRow" Title="{Binding MainlandChinaDisplayTitleText}" Description="{Binding MainlandChinaDisplayDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ComboBox x:Name="MainlandChinaFeatureModeBox" MinWidth="280" SelectedIndex="{Binding MainlandChinaFeatureModeIndex, Mode=TwoWay}">
                        <ComboBoxItem x:Name="MainlandChinaDisabledItem" Content="{Binding MainlandChinaDisabledText}" />
                        <ComboBoxItem x:Name="MainlandChinaFlagOnlyItem" Content="{Binding MainlandChinaFlagOnlyText}" />
                        <ComboBoxItem x:Name="MainlandChinaFlagAndTextItem" Content="{Binding MainlandChinaFlagAndTextText}" />
                        <ComboBoxItem x:Name="MainlandChinaKeywordFilterItem" Content="{Binding MainlandChinaKeywordFilterText}" />
                    </ComboBox>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="MainlandChinaUrlBlockingRow" Title="{Binding MainlandChinaUrlBlockingTitleText}" Description="{Binding MainlandChinaUrlBlockingDescriptionText}">
                <components:SettingRow.ActionContent>
                    <ToggleSwitch x:Name="MainlandChinaUrlBlockingToggle" IsOn="{Binding MainlandChinaUrlBlockingEnabled, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" />
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <TextBlock x:Name="DataSectionTitleText" Text="{Binding DataSectionTitleText}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <components:SettingRow x:Name="ResetAllSettingsRow" Title="{Binding ResetAllSettingsTitleText}" Description="{Binding ResetAllSettingsDescriptionText}">
                <components:SettingRow.ActionContent>
                    <Button x:Name="ResetAllSettingsButton" Click="ResetAllSettingsButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="{Binding ResetText}" />
                        </StackPanel>
                    </Button>
                </components:SettingRow.ActionContent>
            </components:SettingRow>

            <components:SettingRow x:Name="ClearAllDataRow" Title="{Binding ClearAllDataTitleText}" Description="{Binding ClearAllDataDescriptionText}">
                <components:SettingRow.ActionContent>
                    <Button x:Name="ClearAllDataButton" Click="ClearAllDataButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            <TextBlock Text="{Binding CleanupText}" />
                        </StackPanel>
                    </Button>
                </components:SettingRow.ActionContent>
            </components:SettingRow>
        </StackPanel>
    </ScrollViewer>
</Page>
