name: Build and Package Clash#

on:
  push:
    branches: [ "main", "master" ] # 只要你往这两个分支推代码就会触发
  workflow_dispatch: # 允许你手动点击按钮触发

jobs:
  build:
    runs-on: windows-latest

    steps:
    # 1. 直接拉取你当前分支的本地完整代码
    - name: Checkout Code
      uses: actions/checkout@v4
      with:
        submodules: recursive
        fetch-depth: 0

    # 2. 打印当前目录，确保这次真的拉到代码了
    - name: List Files in Workspace
      shell: pwsh
      run: |
        echo "=== 根目录文件列表 ==="
        Get-ChildItem -Path .

    - name: Setup .NET SDK
      uses: actions/setup-dotnet@v4
      with:
        dotnet-version: '8.x'

    - name: Setup MSBuild
      uses: microsoft/setup-msbuild@v2

    - name: Download Mihomo Core
      shell: pwsh
      run: |
        $script = Get-ChildItem -Path . -Filter "Update-Mihomo.ps1" -Recurse | Select-Object -First 1
        if ($script) {
            pwsh $script.FullName
        } else {
            echo "未找到 Update-Mihomo.ps1 脚本，跳过。"
        }
      continue-on-error: true

    # 3. 动态扫描解决方案并执行还原
    - name: Restore NuGet Packages
      shell: pwsh
      run: |
        $sln = Get-ChildItem -Path . -Filter "*.sln" -Recurse | Select-Object -First 1
        if ($sln) {
            echo "找到解决方案: $($sln.FullName)，开始还原..."
            msbuild /t:Restore $sln.FullName
        } else {
            throw "致命错误：在这个分支里依然没有找到任何 *.sln 解决方案文件！"
        }

    # 4. 执行编译
    - name: Build Project
      shell: pwsh
      run: |
        $sln = Get-ChildItem -Path . -Filter "*.sln" -Recurse | Select-Object -First 1
        msbuild $sln.FullName /p:Configuration=Release /p:Platform=x64 /p:AppxBundle=Never /p:OutDir=${{ github.workspace }}\PublishOutput\

    - name: Upload Artifacts
      uses: actions/upload-artifact@v4
      with:
        name: ClashSharp-Windows-x64
        path: ${{ github.workspace }}\PublishOutput\
